DEBUG=true
DJANGO_SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=development
PLAID_PRODUCTS=transactions,investments
PLAID_COUNTRY_CODES=US
PLAID_REDIRECT_URI=
# How far back to ask for transactions (1–730). Used for (1) Link `transactions.days_requested`
# and (2) each /transactions/get date window. Plaid does not deepen history for an Item that was
# already linked with a smaller window—disconnect and reconnect after raising this.
PLAID_TRANSACTION_SYNC_LOOKBACK_DAYS=365
